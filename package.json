{
  "name": "@trelmir-os/input-quality-compiler",
  "version": "0.3.1",
  "description": "Drop in front of any OpenAI / Claude / Gemini call as a token cost-guard. Blocks vague prompts before you pay for them. Deterministic, zero-dependency, sub-millisecond compile.",
  "type": "module",
  "main": "./src/index.mjs",
  "bin": {
    "iqc": "./bin/iqc.mjs"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./dictionary": "./src/brian-term-dictionary.json"
  },
  "files": [
    "src/index.mjs",
    "src/brian-term-dictionary.json",
    "bin/iqc.mjs",
    "assets/demo.svg",
    "scripts/postinstall.mjs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test __tests__/smoke.test.mjs",
    "test:full": "node --test __tests__/smoke.test.mjs __tests__/parity.test.mjs test/parity.test.mjs",
    "postinstall": "node scripts/postinstall.mjs || true",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run",
    "smoke:published": "node scripts/post-publish-smoke.mjs latest",
    "bump:auto": "node scripts/bump-version.mjs",
    "changelog": "node scripts/generate-changelog.mjs",
    "sync-stamps": "node scripts/sync-version-stamps.mjs",
    "status": "node scripts/status.mjs"
  },
  "keywords": [
    "input-normalization",
    "intent-compiler",
    "task-spec",
    "llm-pre-processor",
    "agent-input",
    "prompt-engineering",
    "deterministic",
    "trelmir"
  ],
  "author": "Brian Jones / Trelmir Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lassday/input-quality-compiler.git"
  },
  "bugs": {
    "url": "https://github.com/lassday/input-quality-compiler/issues"
  },
  "homepage": "https://trelmir.dev/iqc",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
